{
  "name": "seorincompany-logistics-portal",
  "version": "1.5.11",
  "description": "서린컴퍼니 물류포털 Windows 데스크톱 앱",
  "main": "main.js",
  "author": "SeorinCompany",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.seorincompany.logisticsportal",
    "productName": "서린컴퍼니 물류포털",
    "artifactName": "SeorinCompany_Setup_${version}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "서린컴퍼니 물류포털",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "language": "1042"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "peek2397-pixel",
        "repo": "SeorinCompany-V52",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  }
}
